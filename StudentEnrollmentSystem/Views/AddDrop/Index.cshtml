@model AddDropIndexViewModel
@{
    ViewData["Title"] = "Course Add / Drop";
}

<section class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Course Add / Drop</h1>
        <p class="text-secondary mb-0">@Model.StudentName | @Model.SemesterName</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="History">View Add/Drop History</a>
</section>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Current Registrations</h2>
            </div>
            <div class="card-body">
                @if (!Model.CurrentEnrollments.Any())
                {
                    <p class="text-secondary mb-0">No active registrations yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                    @foreach (var enrollment in Model.CurrentEnrollments)
                    {
                        <div class="border rounded-3 p-3">
                            <div class="d-flex flex-wrap justify-content-between gap-3">
                                <div>
                                    <div class="fw-semibold">@enrollment.CourseCode - @enrollment.CourseTitle</div>
                                    <div class="text-secondary small">Section @enrollment.SectionCode | @enrollment.CreditHours credit hours</div>
                                    <div class="text-secondary small">@enrollment.ScheduleSummary</div>
                                </div>
                                <div class="text-end">
                                    <div class="text-secondary small mb-2">Enrolled @enrollment.EnrolledAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                    <form asp-action="Drop" method="post" class="d-grid gap-2">
                                        <input type="hidden" name="EnrollmentId" value="@enrollment.EnrollmentId" />
                                        <textarea class="form-control form-control-sm" name="Remarks" rows="2" maxlength="300" placeholder="Reason for dropping" required></textarea>
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Drop Course</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Available To Add</h2>
            </div>
            <div class="card-body">
                @if (!Model.AvailableSections.Any())
                {
                    <p class="text-secondary mb-0">There are no additional sections available to add right now.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                    @foreach (var item in Model.AvailableSections)
                    {
                        <div class="border rounded-3 p-3">
                            <div class="fw-semibold">@item.CourseCode - @item.CourseTitle</div>
                            <div class="text-secondary small">Section @item.SectionCode | Seats left: @item.SeatsRemaining</div>
                            <div class="text-secondary small">@item.ScheduleSummary</div>
                            <div class="text-secondary small mb-3">Instructor: @item.InstructorName</div>
                            <form asp-action="Add" method="post">
                                <input type="hidden" name="sectionId" value="@item.SectionId" />
                                <button type="submit" class="btn btn-primary btn-sm">Add Course</button>
                            </form>
                        </div>
                    }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
