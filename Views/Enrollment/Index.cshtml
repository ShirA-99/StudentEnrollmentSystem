@model EnrollmentIndexViewModel
@{
    ViewData["Title"] = "Enrollment";
}

<section class="portal-hero portal-hero-compact mb-4" data-reveal="left">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <span class="portal-eyebrow">Enrollment</span>
            <h1 class="h2 mb-1">Plan your timetable for @Model.SemesterName</h1>
            <p class="text-secondary mb-1">@Model.StudentName (@Model.StudentNumber) | @Model.ProgramName</p>
            <p class="text-secondary mb-1">Academic timeline: @Model.RegistrationWindow</p>
            <p class="text-secondary mb-0">Only sections approved for your programme are shown here.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="portal-chip">Programme planning</span>
            <a class="btn btn-outline-primary" asp-controller="AddDrop" asp-action="Index">Open Add / Drop</a>
        </div>
    </div>

    <div class="alert @(Model.IsRegistrationOpen ? "alert-success" : "alert-warning") portal-status-banner mb-4" role="status">
        @Model.RegistrationStatusMessage
    </div>

    <div class="row g-3">
        <div class="col-sm-6 col-xl-3" data-reveal data-delay="40">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Active enrollments</span>
                <div class="stat-value">@Model.ActiveEnrollmentCount</div>
                <div class="stat-meta">@Model.IntakeLabel intake</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3" data-reveal data-delay="80">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Credit hours</span>
                <div class="stat-value">@Model.CurrentCreditHours</div>
                <div class="stat-meta">Current study load for the active semester</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3" data-reveal data-delay="120">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Available sections</span>
                <div class="stat-value">@Model.AvailableSectionCount</div>
                <div class="stat-meta">Open sections you can still select for this semester</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3" data-reveal data-delay="160">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Recent activity</span>
                <div class="stat-meta stat-meta-strong">@Model.RecentActivityText</div>
            </div>
        </div>
    </div>
</section>

@if (!Model.AvailableSections.Any())
{
        <div class="portal-surface empty-state" data-reveal>
            <h2 class="h4 mb-2">No additional sections are available right now</h2>
            <p class="text-secondary mb-3">
                @(Model.IsRegistrationOpen
                    ? "You may already be registered for the remaining courses, or the open sections approved for your programme have reached capacity."
                    : "There are no programme-approved planning sections available to display for this semester at the moment.")
            </p>
            <a class="btn btn-outline-primary" asp-controller="AddDrop" asp-action="Index">Review Current Timetable</a>
        </div>
}
else
{
    <section class="row g-4">
        @for (var index = 0; index < Model.AvailableSections.Count; index++)
        {
            var item = Model.AvailableSections[index];
            <div class="col-xl-6" data-reveal="right" data-delay="@(index * 45)">
                <article class="section-card portal-surface h-100">
                    <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                        <div>
                            <div class="section-course-code">@item.CourseCode</div>
                            <h2 class="h4 mb-1">@item.CourseTitle</h2>
                            <div class="section-subtitle">Section @item.SectionCode</div>
                        </div>
                        <div class="section-chips">
                            <span class="portal-chip">@item.CreditHours credit hours</span>
                            <span class="portal-chip portal-chip-contrast">@item.SeatsRemaining seats left</span>
                        </div>
                    </div>
                    <div class="section-detail-grid mb-4">
                        <div class="section-detail">
                            <span class="section-detail-label">Schedule</span>
                            <span class="section-detail-value">@item.ScheduleSummary</span>
                        </div>
                        <div class="section-detail">
                            <span class="section-detail-label">Lecturer</span>
                            <span class="section-detail-value">@item.InstructorName</span>
                        </div>
                    </div>
                    <form asp-action="Enroll" method="post" class="d-flex justify-content-end">
                        <input type="hidden" name="sectionId" value="@item.SectionId" />
                        <button type="submit" class="btn btn-primary" disabled="@(!Model.IsRegistrationOpen)">
                            @(Model.IsRegistrationOpen ? "Add To Semester Timetable" : "Registration Unavailable")
                        </button>
                    </form>
                </article>
            </div>
        }
    </section>
}
