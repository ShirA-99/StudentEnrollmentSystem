@model StudentEnrollmentSystem.Models.StudentProfile
@using StudentEnrollmentSystem.Models

@{
    ViewData["Title"] = "Statement";

    var currentSemesterId = Model.CurrentSemesterId;
    var activeSemester = Model.CurrentSemester?.Name ?? "Current Semester";

    var records = Model.EnrollmentRecords?
        .Where(e =>
            e.Status == EnrollmentStatus.Enrolled &&
            e.CourseSection != null &&
            e.CourseSection.Course != null &&
            e.CourseSection.SemesterId == currentSemesterId
        )
        .ToList() ?? new List<EnrollmentRecord>();

    var totalSubjects = records.Count;
    var totalCredits = records.Sum(e => e.CourseSection.Course.CreditHours);
    var totalFee = records.Sum(e => e.CourseSection.Course.Fee);

    // 先不接 payment module，避免引入额外复杂度
    var paidAmount = 0m;
    var outstandingBalance = totalFee - paidAmount;
}

<section class="portal-hero mb-4">
    <div class="d-flex justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <span class="portal-eyebrow">Statement overview</span>
            <h1 class="h2 mb-2">Fee and Registration Statement</h1>

            <div class="text-secondary">
                @Model.FullName |
                @Model.StudentNumber |
                @Model.Email |
                @activeSemester
            </div>
        </div>

        <div>
            <a asp-action="Timetable" class="btn btn-outline-primary">
                View Timetable
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Subjects</span>
                <div class="stat-value">@totalSubjects</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Credit Hours</span>
                <div class="stat-value">@totalCredits</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Total Fee</span>
                <div class="stat-value">RM @totalFee</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Outstanding Balance</span>
                <div class="stat-value">RM @outstandingBalance</div>
            </div>
        </div>
    </div>
</section>

<section id="statementPrintArea" class="portal-surface">
    <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
        <div>
            <span class="portal-eyebrow">Registered subjects</span>
            <h2 class="h4 mb-1">Current Semester Subjects</h2>

            <div class="fw-semibold" style="color:#163a63;">
                @Model.FullName &nbsp;&nbsp;|&nbsp;&nbsp;
                @Model.StudentNumber &nbsp;&nbsp;|&nbsp;&nbsp;
                @Model.Email &nbsp;&nbsp;|&nbsp;&nbsp;
                @activeSemester
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="button" onclick="printStatementSection()" class="btn btn-outline-dark">
                Print / Download PDF
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Course Code</th>
                    <th>Course Name</th>
                    <th>Lecturer</th>
                    <th>Section</th>
                    <th>Credit</th>
                    <th>Fee (RM)</th>
                </tr>
            </thead>

            <tbody>
                @if (records.Any())
                {
                    @foreach (var r in records)
                    {
                        <tr>
                            <td class="fw-semibold">@r.CourseSection.Course.Code</td>
                            <td>@r.CourseSection.Course.Title</td>
                            <td>@r.CourseSection.InstructorName</td>
                            <td>@r.CourseSection.SectionCode</td>
                            <td>@r.CourseSection.Course.CreditHours</td>
                            <td>@r.CourseSection.Course.Fee</td>
                        </tr>
                    }

                    <tr class="fw-bold table-light">
                        <td colspan="4" class="text-end">TOTAL</td>
                        <td>@totalCredits</td>
                        <td>RM @totalFee</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-secondary">
                            No registered subjects found for @activeSemester.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    
        <div class="text-secondary small">
            * Fees shown above are retrieved from the current database records.
        </div>

        <div>
            @if (outstandingBalance > 0)
            {
                <a asp-controller="Payment"
                asp-action="Index"
                class="btn btn-primary px-4 py-2 fw-semibold rounded-pill shadow-sm">
                    Proceed to Payment (RM @outstandingBalance)
                </a>
            }
            else
            {
                <button class="btn btn-success px-4 py-2 rounded-pill" disabled>
                    All Fees Paid
                </button>
            }
    </div>
</div>
</section>

<script>
    function printStatementSection() {
        const printContents = document.getElementById("statementPrintArea").innerHTML;
        const originalContents = document.body.innerHTML;

        document.body.innerHTML = `
            <html>
            <head>
                <title>Statement</title>
                <style>
                    body {
                        font-family: Arial, sans-serif;
                        padding: 24px;
                        color: #212529;
                    }

                    h1, h2, h3, h4 {
                        margin-bottom: 12px;
                        color: #163a63;
                    }

                    .portal-eyebrow {
                        display: inline-block;
                        font-size: 12px;
                        font-weight: 700;
                        text-transform: uppercase;
                        letter-spacing: 0.08em;
                        color: #0b6a88;
                        margin-bottom: 8px;
                    }

                    .text-secondary {
                        color: #6c757d !important;
                    }

                    .fw-semibold {
                        font-weight: 600;
                    }

                    .fw-bold {
                        font-weight: 700;
                    }

                    .table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-top: 16px;
                    }

                    .table th,
                    .table td {
                        border: 1px solid #dee2e6;
                        padding: 10px 12px;
                        text-align: left;
                        vertical-align: middle;
                    }

                    .table thead th {
                        background-color: #f8f9fa;
                    }

                    .table-light {
                        background-color: #f8f9fa;
                    }

                    .btn {
                        display: none !important;
                    }

                    .table-responsive {
                        overflow: visible !important;
                    }
                </style>
            </head>
            <body>
                ${printContents}
            </body>
            </html>
        `;

        window.print();
        document.body.innerHTML = originalContents;
        location.reload();
    }
</script>