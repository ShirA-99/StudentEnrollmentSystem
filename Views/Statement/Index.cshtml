@model StudentEnrollmentSystem.Models.StudentProfile
@using StudentEnrollmentSystem.Models

@{
    ViewData["Title"] = "Statement";
    var enrolledRecords = Model.EnrollmentRecords?
        .Where(e => e.Status == EnrollmentStatus.Enrolled)
        .ToList() ?? new List<EnrollmentRecord>();

    var totalFee = enrolledRecords.Count * 1000;
    var paidAmount = 1000;
    var outstandingBalance = totalFee - paidAmount;
}

<section class="portal-hero mb-4" data-reveal="left">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
        <div>
            <span class="portal-eyebrow">Statement overview</span>
            <h1 class="h2 mb-2">Fee and registration statement</h1>
            <p class="portal-lead mb-0">View your student profile, registered subjects, and fee summary for the current semester.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <span class="portal-chip">RM-ready summary</span>
            <a asp-controller="Statement" asp-action="Timetable" class="btn btn-outline-primary">
                View Class Timetable
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4" data-reveal data-delay="40">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Student name</span>
                <div class="stat-value">@Model.FullName</div>
                <div class="stat-meta">Student ID: @Model.StudentNumber</div>
            </div>
        </div>
        <div class="col-md-4" data-reveal data-delay="80">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Programme</span>
                <div class="stat-value">@Model.ProgramName</div>
                <div class="stat-meta">Intake: @Model.IntakeLabel</div>
            </div>
        </div>
        <div class="col-md-4" data-reveal data-delay="120">
            <div class="portal-surface stat-card h-100">
                <span class="stat-label">Current subjects</span>
                <div class="stat-value">@enrolledRecords.Count</div>
                <div class="stat-meta">Active registrations in the current semester</div>
            </div>
        </div>
    </div>
</section>

<section class="row g-4 mb-4">
    <div class="col-md-4" data-reveal="left">
        <div class="portal-surface stat-card h-100">
            <span class="stat-label">Total fee</span>
            <div class="stat-value">RM @totalFee</div>
            <div class="stat-meta">Current semester charges</div>
        </div>
    </div>
    <div class="col-md-4" data-reveal data-delay="60">
        <div class="portal-surface stat-card h-100">
            <span class="stat-label">Paid amount</span>
            <div class="stat-value">RM @paidAmount</div>
            <div class="stat-meta">Payments recorded so far</div>
        </div>
    </div>
    <div class="col-md-4" data-reveal="right" data-delay="120">
        <div class="portal-surface stat-card h-100">
            <span class="stat-label">Outstanding balance</span>
            <div class="stat-value">RM @outstandingBalance</div>
            <div class="stat-meta">Remaining amount to be paid</div>
        </div>
    </div>
</section>

<section class="portal-surface" data-reveal="right">
    <div class="mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <span class="portal-eyebrow">Registered subjects</span>
            <h2 class="h4 mb-0">Current semester subjects</h2>
        </div>
        <span class="portal-chip portal-chip-contrast">@enrolledRecords.Count registered</span>
    </div>

    <div class="table-responsive">
        <table class="table portal-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Course code</th>
                    <th>Course name</th>
                    <th>Section</th>
                    <th>Fee</th>
                </tr>
            </thead>
            <tbody>
                @if (enrolledRecords.Any())
                {
                    @foreach (var record in enrolledRecords)
                    {
                        <tr>
                            <td class="fw-semibold">@record.CourseSection.Course.Code</td>
                            <td>
                                <div class="fw-semibold">@record.CourseSection.Course.Title</div>
                            </td>
                            <td>@record.CourseSection.SectionCode</td>
                            <td>RM 1000</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-secondary">
                            No registered subjects found for the current semester.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
